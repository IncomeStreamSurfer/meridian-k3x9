---
const navLinks = [
  { href: '/#origin', label: 'Origin' },
  { href: '/#craft', label: 'Craft' },
  { href: '/our-story', label: 'Our Story' },
  { href: '/#waitlist', label: 'Waitlist' },
];
---
<header class="relative z-30">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-6 pb-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <svg width="32" height="32" viewBox="0 0 32 32" class="text-copper" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="16" cy="16" r="13" />
        <path d="M3 16 h26 M16 3 v26" stroke-opacity="0.55" />
        <circle cx="16" cy="16" r="4" fill="currentColor" />
      </svg>
      <span class="font-display text-xl tracking-tight">Meridian</span>
      <span class="hidden sm:inline-block font-mono text-[10px] uppercase tracking-[0.18em] text-stone border border-current/30 px-1.5 py-0.5 rounded-sm">Coming Soon</span>
    </a>
    <nav class="hidden md:flex items-center gap-8 font-mono text-[11px] uppercase tracking-[0.18em]">
      {navLinks.map((l) => (
        <a href={l.href} class="opacity-70 hover:opacity-100 hover:text-copper transition">{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <button data-theme-toggle aria-label="Toggle theme" class="w-9 h-9 grid place-items-center rounded-full border border-current/20 hover:border-copper hover:text-copper transition">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M10 2 a8 8 0 1 0 0 16 a6 6 0 0 1 0 -16 z" />
        </svg>
      </button>
      <a href="/#waitlist" class="hidden sm:inline-block font-mono text-[11px] uppercase tracking-[0.18em] px-4 py-2 rounded-full bg-ink text-cream hover:bg-copper transition">Join Waitlist</a>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 lg:px-10"><div class="hairline"></div></div>
</header>
