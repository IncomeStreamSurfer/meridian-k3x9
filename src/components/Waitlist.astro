---
---
<section id="waitlist" class="relative py-24 md:py-36 overflow-hidden">
  <div class="absolute inset-0 -z-10 opacity-30 pointer-events-none">
    <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 1000 600" fill="none" stroke="currentColor" stroke-width="0.5">
      {Array.from({ length: 9 }).map((_, i) => (
        <ellipse cx="500" cy="300" rx={80 + i * 50} ry={30 + i * 20} stroke-opacity={0.25 - i * 0.02} />
      ))}
    </svg>
  </div>
  <div class="max-w-3xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-3 mb-6">
      <span class="inline-block w-8 h-px bg-copper"></span>
      <span class="font-mono text-[11px] uppercase tracking-[0.26em] text-copper">Join the Waitlist</span>
      <span class="inline-block w-8 h-px bg-copper"></span>
    </div>
    <h2 class="font-display text-4xl md:text-6xl leading-[1.05] tracking-tight">Be the first to taste<br/>what's been brewing.</h2>
    <p class="mt-6 text-lg opacity-75 max-w-xl mx-auto leading-relaxed">Enter your email to receive founder's letters from origin, early-access pricing on the debut drop, and a private code reserved for first-list members.</p>
    <form id="waitlist-form" class="mt-10 max-w-xl mx-auto flex flex-col sm:flex-row gap-3" novalidate>
      <input type="email" name="email" required placeholder="you@yourmorning.com" autocomplete="email" class="flex-1 px-5 py-4 rounded-full bg-transparent border border-current/25 focus:border-copper focus:outline-none focus:ring-2 focus:ring-copper/20 font-mono text-sm placeholder:opacity-40 transition" />
      <button type="submit" class="group inline-flex items-center justify-center gap-3 bg-ink text-cream px-7 py-4 rounded-full font-mono text-[11px] uppercase tracking-[0.22em] hover:bg-copper transition disabled:opacity-60 disabled:cursor-wait">
        <span data-label>Reserve my seat</span>
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" class="group-hover:translate-x-1 transition"><path d="M4 10 h12 m-5 -5 5 5 -5 5" /></svg>
      </button>
    </form>
    <p id="waitlist-message" class="mt-5 font-mono text-xs uppercase tracking-[0.2em] min-h-[1.25rem]" aria-live="polite"></p>
    <p class="mt-8 text-xs opacity-50 max-w-md mx-auto">We send at most one email per month. No spam, no resold lists, unsubscribe any time.</p>
  </div>
  <script is:inline>
    (function () {
      const form = document.getElementById('waitlist-form');
      if (!form) return;
      const msg = document.getElementById('waitlist-message');
      const btn = form.querySelector('button[type="submit"]');
      const label = btn.querySelector('[data-label]');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = form.email.value.trim();
        if (!email || !email.includes('@')) { msg.textContent = 'Please enter a valid email.'; msg.style.color = '#b87333'; return; }
        btn.disabled = true; label.textContent = 'Reserving…'; msg.textContent = '';
        try {
          const res = await fetch('/api/waitlist', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, source: window.location.pathname }) });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || 'Something went wrong');
          window.location.href = '/thanks';
        } catch (err) { msg.textContent = err.message || 'Could not subscribe. Try again.'; msg.style.color = '#b87333'; btn.disabled = false; label.textContent = 'Reserve my seat'; }
      });
    })();
  </script>
</section>
